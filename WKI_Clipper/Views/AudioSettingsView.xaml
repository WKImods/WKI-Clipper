<UserControl x:Class="WKI_Clipper.Views.AudioSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Style="{StaticResource HeadingStyle}" Text="Audio" />
            <TextBlock Style="{StaticResource MutedStyle}" Margin="0,0,0,16"
                       Text="Mikrofon + System-Sound werden direkt via WASAPI in der App gecapturet — kein Stereo-Mix oder VB-CABLE nötig." />

            <StackPanel x:Name="RowsContainer" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
