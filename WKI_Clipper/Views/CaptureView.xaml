<UserControl x:Class="WKI_Clipper.Views.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource HeadingStyle}" Text="Aufnahme" />
            <TextBlock Style="{StaticResource MutedStyle}" Margin="0,0,0,16"
                       Text="Was geclippt wird — gilt für F9-Clip und Strg+F9-Aufnahme gleichermaßen. Änderungen wirken sofort." />

            <StackPanel x:Name="RowsContainer" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
